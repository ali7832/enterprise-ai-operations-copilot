APP_ENV=local
APP_NAME=enterprise-ai-operations-copilot
APP_PORT=8000
USE_LANGGRAPH=true
POSTGRES_DSN=postgresql://copilot:copilot@postgres:5432/copilot
REDIS_URL=redis://redis:6379/0
OPENSEARCH_URL=http://opensearch:9200
USE_POSTGRES_PERSISTENCE=false
USE_REDIS_CACHE=false
USE_OPENSEARCH_RUNBOOKS=false
WORKFLOW_CACHE_TTL_SECONDS=900
OPENSEARCH_RUNBOOK_INDEX=runbooks
WORKFLOW_RUNS_PATH=fixtures/workflow_runs.jsonl
RUNBOOK_FIXTURE_PATH=fixtures/runbooks.json
INCIDENT_FIXTURE_PATH=fixtures/sample_incident.json
MAX_RUNBOOK_RESULTS=3
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
AWS_REGION=us-east-1
AWS_ECS_CLUSTER=enterprise-ai-ops
AWS_RDS_INSTANCE=enterprise-ai-ops-db
AWS_OPENSEARCH_DOMAIN=enterprise-ai-ops-search
AWS_ELASTICACHE_CLUSTER=enterprise-ai-ops-cache
AI_PROVIDER_LABEL=OpenAI-compatible
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_REQUEST_TIMEOUT_SECONDS=45
AI_SYSTEM_PROMPT="You are an enterprise incident copilot. Help operators understand the incident, recommend the next safest actions, and draft concise stakeholder updates."
